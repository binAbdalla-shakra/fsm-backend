          }
        }
      ]
    },
    {
      "name": "Technicians",
      "item": [
        {
          "name": "Register Technician",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+252616660200\",\n  \"email\": \"technician@hormuud.com\",\n  \"name\": \"Abdi Farah\",\n  \"skills\": [\"Fiber Optic\", \"Router Setup\", \"General Troubleshooting\"],\n  \"zone_assignment\": \"Waberi\",\n  \"latitude\": 2.0396,\n  \"longitude\": 45.3182\n}"
            },
            "url": {
              "raw": "{{base_url}}/technicians",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "technicians"
              ]
            },
            "description": "Creates a new core user with role 'TECHNICIAN' and builds their technician profile. The coordinates register their initial GPS coordinates in Mogadishu (SRID 4326)."
          }
        },
        {
          "name": "Get Technician Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/technicians/profile",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "technicians",
                "profile"
              ]
            },
            "description": "Retrieves profiles, active status, completed tasks counters, dynamic ratings, and stats of the logged-in technician matching their token."
          }
        },
        {
          "name": "Update Technician Status/Location",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ONLINE\",\n  \"latitude\": 2.0396,\n  \"longitude\": 45.3182\n}"
            },
            "url": {
              "raw": "{{base_url}}/technicians/status",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "technicians",
                "status"
              ]
            },
            "description": "Updates status ('ONLINE', 'OFFLINE') and coordinate location pins for the logged-in technician matching their token. Needed for proximity auto-dispatching."
          }
        },
        {
          "name": "Get Technician Assigned Tickets",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/technicians/tickets?status=COMPLETED",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "technicians",
                "tickets"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "COMPLETED",
                  "description": "Filter by status (e.g. COMPLETED to view finished tasks, or omit for all assigned)"
                }
              ]
            },
            "description": "Retrieves assigned tickets list (or specific completed tasks) of the logged-in technician matching their token."
          }
        }
      ]
    },
    {
      "name": "Tickets",
      "item": [
        {
          "name": "Report Ticket",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Complete Fiber Link Outage\",\n  \"description\": \"Broadband red alarm lamp is flashing. I checked local router cabling.\",\n  \"skill_required\": \"Fiber Optic\",\n  \"landmark\": \"Opposite Shamo Hotel\",\n  \"latitude\": 2.0378,\n  \"longitude\": 45.3150\n}"
            },
            "url": {
              "raw": "{{base_url}}/tickets",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets"
              ]
            },
            "description": "Reports a connection issue. Requires Bearer JWT with `ticket:create` permission. Immediately triggers proximity-based matching routines."
          }
        },
        {
          "name": "Get Ticket Details",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/:id",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "paste_ticket_uuid_here"
                }
              ]
            },
            "description": "Fetches state, category, assigned technician ID, and completion OTP verification code of a ticket."
          }
        },
        {
          "name": "Proximity Auto-Dispatch",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/tickets/:id/dispatch",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                ":id",
                "dispatch"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "paste_ticket_uuid_here"
                }
              ]
            },
            "description": "Matches coordinates of the reported ticket to the closest 'ONLINE' technician with 0 workload and matching skills within 50km. Requires `ticket:dispatch` permission."
          }
        },
        {
          "name": "Direct Assign Ticket (By ID or Number Reference)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"technician_id\": \"paste_technician_uuid_here\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tickets/:id/assign",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                ":id",
                "assign"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "paste_ticket_uuid_or_reference_here"
                }
              ]
            },
            "description": "Directly assigns a ticket (either using ID or reference code e.g. TK-49291) to a technician. Requires `ticket:dispatch` permission."
          }
        },
        {
          "name": "Start Work (Before Photo)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "X-Device-ID",
                "value": "postman_device_001"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "before_photo",
                  "description": "Arrived state photo (optional upload)",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/tickets/:id/start",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                ":id",
                "start"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "paste_ticket_uuid_here"
                }
              ]
            },
            "description": "Transitions ticket status to 'IN_PROGRESS'. The technician uploads their arrival proof photo. Requires Bearer JWT of assigned technician (`ticket:update` permission)."
          }
        },
        {
          "name": "Complete Work (After Photo & Customer OTP)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "X-Device-ID",
                "value": "postman_device_001"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "otp",
                  "value": "123456",
                  "description": "4-to-6 digit customer completion verification code",
                  "type": "text"
                },
                {
                  "key": "after_photo",
                  "description": "Resolution state photo (optional upload)",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/tickets/:id/complete",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                ":id",
                "complete"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "paste_ticket_uuid_here"
                }
              ]
            },
            "description": "Submits work resolution details. Verifies the OTP matching the customer's secret code. Closes the ticket state to 'COMPLETED'. Requires `ticket:update` permission."
          }
        },
        {
          "name": "Submit Ticket Rating / Review",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"tags\": [\"Fast\", \"Polite\", \"Professional\"],\n  \"comment\": \"Excellent service. The technician resolved the issue very quickly!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/tickets/:id/review",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "tickets",
                ":id",
                "review"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "paste_ticket_uuid_here"
                }
              ]
            },
            "description": "Submits customer feedback on a completed ticket and updates the technician's average rating in the system."
          }
        }
      ]
    },
    {
      "name": "WebSockets GPS Tracking",
      "item": [
        {
          "name": "Technician Live Telemetry",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "ws://localhost:8080/ws/tracking/tech/:tech_id?ticket_id=paste_ticket_uuid_here",
              "protocol": "ws",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "ws",
                "tracking",
                "tech",
                ":tech_id"
              ],
              "query": [
                {
                  "key": "ticket_id",
                  "value": "paste_ticket_uuid_here"
                }
              ],
              "variable": [
                {
                  "key": "tech_id",
                  "value": "paste_technician_uuid_here"
                }
              ]
            },
            "description": "WebSocket URL. Technician uploads GPS pings formatted as raw JSON: `{\"latitude\": 2.0396, \"longitude\": 45.3182, \"speed\": 4.2, \"bearing\": 120.0}`. Updates Redis caching and streams coordinates to subscribers."
          }
        },
        {
          "name": "Customer Tracking Subscriber",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "ws://localhost:8080/ws/tracking/customer/:ticket_id",
              "protocol": "ws",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "ws",
                "tracking",
                "customer",
                ":ticket_id"
              ],
              "variable": [
                {
                  "key": "ticket_id",
                  "value": "paste_ticket_uuid_here"
                }
              ]
            },
            "description": "WebSocket URL. Upgrades customer connection. Broadcasts real-time technician routes, current speed, and heading telemetry straight to the client screen."
          }
        }
      ]
    }
  ],
